{
	"name" : "robert/http",
	"license" : "MIT",
	"require" : {
		"php" : ">=7.1"
	},
	"require-dev" : {
		"phpunit/phpunit" : "^7"
	},
	"autoload" : {
		"psr-4" : {
			"RHo\\Http\\" : [
				"src/",
				"src/media-type/",
				"src/request/"
			],
			"RHo\\Http\\Content\\" : "src/content-filter/",
			"RHo\\Http\\Header\\" : "src/header/",
			"RHo\\Http\\Response\\" : "src/response/"
		}
	},
	"autoload-dev" : {
		"psr-4" : {
			"RHo\\HttpTest\\" : [
				"tests/",
				"tests/media-type/",
				"tests/request/",
				"tests/response/",
				"tests/content-filter/",
				"tests/header/"
			]
		}
	}
}
