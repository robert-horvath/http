{
	"name" : "robert/http",
	"license" : "MIT",
	"minimum-stability" : "dev",
	"require" : {
		"php" : ">=7.1",
		"robert/http-request" : "master-dev",
		"robert/http-response" : "master-dev",
		"robert/http-header" : "master-dev",
		"robert/stable-sort" : "dev-master"
	},
	"require-dev" : {
		"phpunit/phpunit" : "^7"
	},
	"autoload" : {
		"psr-4" : {
			"RHo\\Http\\" : "src/"
		}
	},
	"autoload-dev" : {
		"files" : [
			"tests/mock_functions.php"
		],
		"psr-4" : {
			"RHo\\HttpTest\\" : "tests/"
		}
	}
}